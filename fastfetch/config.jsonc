{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "source": "~/.config/fastfetch/ASCII/makima_small.ansi",
    "color":{
      "1": "35"
    },
    "padding":{
      "top":1,
      "left":2,
      "right":2,
      "bottom":2
    }
  },  
  "display": {
    "separator": " ",
    "color": {
      "keys": "35", 
      "title": "34"
    }
  },
  "modules": [

    // User
    {
      "type": "title"
    },
    {
      "type":"colors",
      "symbol":"circle"
    },
    // OS
    { "type": "os", "key": "{#34}  System " },

    { "type": "kernel", "key": "{#34}    Kernel " },
    { "type": "de", "key": "{#34}    DE " },
    { "type": "wm", "key": "{#34}    WM " },
    { "type": "uptime", "key": "{#34}    Uptime" },

    { "type": "custom", "format": "" },

    // Hardware -- Idk man
    {
      "type": "host",
      "key": "{#34} {#35}󰇅 Hardware "
    },

    { "type": "cpu", "key": "{#35}    CPU", "showTemp": true },
    { "type": "gpu", "key": "{#35}  󰢮  GPU" },
    { "type": "memory", "key": "{#35}  󰍛  RAM" },
    { "type": "disk", "key": "{#35}  󱛟  Disk", "showUsed": true },

    { "type": "custom", "format": "" },

    // Development
    {
      "type": "custom",
      "format": "{#34} {#32} Development "
    },

    {
      "type": "command",
      "key": "{#32}    Godot",
      "text": "godot --version | cut -d'.' -f1-3",
      "shell": "/bin/sh"
    },
    {
      "type": "command",
      "key": "{#32}    Python",
      "text": "python3 --version | cut -d' ' -f2",
      "shell": "/bin/sh"
    },
    {
      "type": "command",
      "key": "{#32}    Node",
      "text": "node --version | cut -d' ' -f2",
      "shell": "/bin/sh"
    },
    {
      "type": "command",
      "key": "{#32}  󰊤  Repositories",
      "text": "ls ~/Development/Repositories | wc -l",
      "shell": "/bin/sh"
    },
    { "type": "custom", "format": "" },

    {
      "type": "colors",
      "symbol":"circle"
    }
  ]
}
